# MangaMetaManager Configuration

# Server Settings
server:
  port: 8080
  host: "0.0.0.0"

# Database Settings
database:
  path: "mmm.db"

# Library Settings
library:
  # Folder settings are managed via UI/CLI and stored in DB.
  # (Placeholder for future global library settings)

# Logging Settings
logging:
  path: "logs/mmm.log"
  max_size_mb: 1024
  max_age_days: 30
